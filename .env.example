# RingCentral (JWT server-to-server auth)
RC_CLIENT_ID=
RC_CLIENT_SECRET=
RC_JWT=
RC_SERVER=https://platform.ringcentral.com

# Redis — use EITHER Vercel KV (auto-injected on Vercel) OR direct Upstash.
# On Vercel, these are injected automatically when you create a KV store.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# For local dev against a direct Upstash DB, use these instead:
# UPSTASH_REDIS_URL=
# UPSTASH_REDIS_TOKEN=

# Deepgram (for post-call transcription)
DEEPGRAM_API_KEY=

# GPT Action API key (any random string — ChatGPT uses this in x-api-key header)
CALL_BRIDGE_API_KEY=

# Phase 2 — softphone sidecar
SOFTPHONE_BRIDGE_URL=http://localhost:8787
SOFTPHONE_BRIDGE_API_KEY=
MONITORED_EXTENSIONS=

# Phase 3 — HubSpot integration
# Create a Private App in HubSpot Settings -> Integrations -> Private Apps.
# Grant scopes: crm.objects.contacts.{read,write}, crm.objects.deals.{read,write}
HUBSPOT_PRIVATE_APP_TOKEN=

# --- Scope → Agreement tool ---
# Anthropic (SFW Service Agreement Generator). Server-side only.
ANTHROPIC_API_KEY=
# Optional model override. Default in code: claude-sonnet-4-6
ANTHROPIC_MODEL=

# CallRail (transcript + caller info). Token auth.
CALLRAIL_API_KEY=
CALLRAIL_ACCOUNT_ID=

# HubSpot extras
# Portal ID is used only to build clickable record links (e.g. 8210108).
HUBSPOT_PORTAL_ID=
# Deal property the PandaDoc template reads the SCOPE from. Default: scope_of_work.
# A HubSpot admin must create this custom Deal property (multi-line text), OR set
# this to an existing property the PandaDoc template already tokenizes.
HUBSPOT_SCOPE_PROPERTY=scope_of_work
