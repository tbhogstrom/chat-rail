{
  "name": "sfw-softphone-bridge",
  "version": "0.1.0",
  "description": "RC softphone sidecar — supervises calls and streams audio to Deepgram",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "@upstash/redis": "^1.37.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "ringcentral-softphone": "^1.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.5",
    "vitest": "^4.1.5"
  }
}
